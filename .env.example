# ── Domains ───────────────────────────────────────────────────────────────────
# Public-facing URLs (HAProxy + Cloudflare handle SSL)
VIKUNJA_DOMAIN=tasks.yourdomain.com
OUTLINE_DOMAIN=wiki.yourdomain.com

# ── Host ports (what the Debian VM exposes to HAProxy) ───────────────────────
VIKUNJA_PORT=3456
OUTLINE_PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=webred
POSTGRES_PASSWORD=changeme_strong_password

# ── MinIO (S3-compatible storage for Outline) ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_minio_password

# ── Vikunja ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
VIKUNJA_JWT_SECRET=changeme_generate_random_secret

# ── Outline ───────────────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
OUTLINE_SECRET_KEY=changeme_generate_random_secret
OUTLINE_UTILS_SECRET=changeme_generate_random_secret

# Auth: OIDC (Authentik, Keycloak, Google, etc.) — leave blank to disable
OUTLINE_OIDC_CLIENT_ID=
OUTLINE_OIDC_CLIENT_SECRET=
OUTLINE_OIDC_AUTH_URI=
OUTLINE_OIDC_TOKEN_URI=
OUTLINE_OIDC_USERINFO_URI=
OUTLINE_OIDC_DISPLAY_NAME=SSO

# ── SMTP (shared by Vikunja + Outline) ───────────────────────────────────────
# Required for Outline email magic-link login if OIDC is not configured
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_SECURE=false
