# ── Public URLs ───────────────────────────────────────────────────────────────
# What you type in the browser. Port 7878 is the Nginx front-door.
# Use hostnames that match your /etc/hosts entries (see quickstart below).
VIKUNJA_PUBLIC_URL=http://tasks.lan:7878
OUTLINE_PUBLIC_URL=http://wiki.lan:7878

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=webred
POSTGRES_PASSWORD=changeme_strong_password

# ── MinIO (S3-compatible storage for Outline) ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_minio_password

# ── Vikunja ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
VIKUNJA_JWT_SECRET=changeme_generate_random_secret

# ── Outline ───────────────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
OUTLINE_SECRET_KEY=changeme_generate_random_secret
OUTLINE_UTILS_SECRET=changeme_generate_random_secret

# Auth: OIDC — leave blank to disable
OUTLINE_OIDC_CLIENT_ID=
OUTLINE_OIDC_CLIENT_SECRET=
OUTLINE_OIDC_AUTH_URI=
OUTLINE_OIDC_TOKEN_URI=
OUTLINE_OIDC_USERINFO_URI=
OUTLINE_OIDC_DISPLAY_NAME=SSO

# ── SMTP (needed for Outline email magic-link login if OIDC is not used) ──────
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_SECURE=false
